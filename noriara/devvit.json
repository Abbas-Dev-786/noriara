{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "noriara",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "redis": true,
    "reddit": {
      "enable": true,
      "scope": "moderator"
    }
  },
  "menu": {
    "items": [
      {
        "label": "Create a new post",
        "description": "noriara",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "Configure Noriara event",
        "description": "Create, update, and activate an event",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/event-configure"
      },
      {
        "label": "Deactivate Noriara event",
        "description": "Disable the currently active event",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/event-deactivate"
      }
    ]
  },
  "forms": {
    "eventForm": "/internal/form/event-submit"
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scheduler": {
    "tasks": {
      "archive-yesterday": {
        "endpoint": "/internal/scheduler/archive-yesterday",
        "cron": "5 0 * * *"
      }
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  }
}
